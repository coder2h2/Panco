{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Panco",
  "scopeName": "source.panco",
  "fileTypes": ["pco", "delta"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#brackets_allow"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.panco",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.panco",
          "match": "//.*$"
        }
      ]
    },
    "brackets_allow": {
      "patterns": [
        {
          "name": "meta.variable.brackets.panco",
          "begin": "\\[(allow)\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.variable.begin.panco" },
            "1": { "name": "keyword.declaration.variable.panco" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.variable.end.panco" }
          },
          "patterns": [
            {
              "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\\\",
              "captures": {
                "1": { "name": "variable.other.readwrite.panco" }
              }
            },
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.variable.panco",
          "match": "\\b(allow|let)\\b"
        },
        {
          "name": "keyword.declaration.function.panco",
          "match": "\\b(delta)\\b"
        },
        {
          "name": "keyword.control.panco",
          "match": "\\b(if|else|while|for|in|return)\\b"
        },
        {
          "name": "constant.language.panco",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "keyword.operator.logical.panco",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.control.import.panco",
          "match": "\\b(import|from|import#)\\b"
        },
        {
          "name": "keyword.operator.panco",
          "match": "(\\+|\\-|\\*|\\/|%|=|==|!=|<|<=|>|>=|->)"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.panco",
          "match": "\\b(makeword|len|push|pop|range|type|input|sleep|abs|sqrt|sin|cos)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.panco",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.panco",
              "match": "\\\\."
            },
            {
              "name": "meta.string.interpolation.panco",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.panco",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.panco",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.panco",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
